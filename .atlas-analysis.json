  "keyFeatures": [
    "Multi-agent coordination with automatic handoffs",
    "Vercel AI SDK tool integration",
    "Type-safe structured output with Zod",
    "Natural language to SQL with multi-database support",
    "Local-first RAG with vector embeddings",
    "Context management with multiple rendering formats",
    "LLM evaluation framework with dataset transforms and scoring",
    "Stream persistence for durable AI workflows"
  ],
  "publicApiSurface": [
    "@deepagents/agent: agent, execute, generate, swarm, instructions, toState, toOutput, user",
    "@deepagents/context: XmlRenderer, MarkdownRenderer, TomlRenderer, ToonRenderer, term, hint, guardrail, example, workflow, user, assistant, reminder, SqliteStreamStore, StreamManager",
    "@deepagents/text2sql: SQL adapters (Sqlite, Postgres, SqlServer, MySQL, BigQuery), teachables API, conversational interface",
    "@deepagents/retrieval: ingest, similaritySearch, FastEmbed, SqliteStore, connectors (GitHub, RSS, Files, PDF, Linear)",
    "@deepagents/evals: evaluate, dataset, exactMatch, includes, regex, levenshtein, jsonMatch, factuality, RunStore, EvalEmitter, compareRuns, consoleReporter",
    "@deepagents/orchestrator: High-level agent orchestration utilities",
    "@deepagents/toolbox: Pre-built tools for agents"
  ]
